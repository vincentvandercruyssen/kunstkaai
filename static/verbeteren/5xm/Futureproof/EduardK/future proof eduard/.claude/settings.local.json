{
  "permissions": {
    "allow": [
      "Bash(node server.js)",
      "Bash(curl -s -o /dev/null -w \"%{http_code}\" http://localhost:8000/)",
      "Bash(open http://localhost:8000)",
      "Bash(curl -s http://localhost:8000/)",
      "Bash(curl -s -X POST http://localhost:8000/v1/messages -H 'Content-Type: application/json' -d '{\"model\":\"claude-sonnet-4-6\",\"max_tokens\":50,\"messages\":[{\"role\":\"user\",\"content\":\"hi\"}]}')",
      "Bash(curl -s -X POST http://localhost:8000/v1/messages -H 'Content-Type: application/json' -H 'Authorization: Bearer ' -d '{ *)",
      "Bash(lsof -iTCP -sTCP:LISTEN -P)",
      "Bash(curl -v -X POST http://localhost:8000/v1/messages -H 'Content-Type: application/json' -H 'Authorization: Bearer ' -d '{ *)",
      "Bash(curl -si -X POST http://localhost:8000/v1/messages -H 'Content-Type: application/json' -H 'Authorization: Bearer ' -d '{\"model\":\"claude-sonnet-4-6\",\"max_tokens\":50,\"system\":\"You are a helpful assistant.\",\"messages\":[{\"role\":\"user\",\"content\":\"hi\"}]}')"
    ]
  }
}
